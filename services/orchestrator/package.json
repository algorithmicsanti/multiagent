    "@wm/db": "workspace:*",
    "@wm/observability": "workspace:*",
    "bullmq": "^5.30.1",
    "ioredis": "^5.4.2"
  },
  "devDependencies": {
    "@types/node": "^22.10.2",
    "tsup": "^8.3.5",
    "tsx": "^4.19.2",
    "typescript": "^5.7.2"
  }
}
