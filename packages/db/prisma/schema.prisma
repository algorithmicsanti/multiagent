generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

enum MissionStatus {
  NEW
  PLANNING
  DISPATCHING
  RUNNING
  WAITING_RESULT
  REVIEWING
  WAITING_APPROVAL
  BLOCKED
  FAILED
  DONE
  CANCELLED
}

enum TaskStatus {
  PENDING
  ENQUEUED
  RUNNING
  COMPLETED
  FAILED
  CANCELLED
  WAITING_APPROVAL
  BLOCKED
}

enum AgentType {
  ORCHESTRATOR
  RESEARCH
  FRONTEND
  BACKEND
  DEVOPS
  PROMPTOPS
}

enum ApprovalStatus {
  PENDING
  APPROVED
  REJECTED
  EXPIRED
}

enum ArtifactType {
  DOCUMENT
  BRANCH
  PR
  FILE
  URL
  CODE_SNIPPET
}

model Mission {
  id          String        @id @default(cuid())
  title       String
  description String
  status      MissionStatus @default(NEW)
  priority    Int           @default(5)
  createdBy   String
  currentStep String?
  budgetLimit Decimal?      @db.Decimal(10, 4)
  metadata    Json?

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  tasks     Task[]
  eventLogs EventLog[]
  approvals Approval[]
  artifacts Artifact[]

  @@index([status])
  @@index([createdAt])
}

model Task {
  id               String     @id @default(cuid())
  missionId        String
  agentType        AgentType
  title            String
  instructions     String
  status           TaskStatus @default(PENDING)
  retries          Int        @default(0)
  maxRetries       Int        @default(3)
  timeoutSeconds   Int        @default(300)
  requiresApproval Boolean    @default(false)
  dependsOn        String[]
  metadata         Json?

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  mission   Mission    @relation(fields: [missionId], references: [id], onDelete: Cascade)
  runs      TaskRun[]
  approvals Approval[]
  artifacts Artifact[]
  eventLogs EventLog[]

  @@index([missionId])
  @@index([status])
  @@index([agentType])
}

model TaskRun {
  id           String   @id @default(cuid())
  taskId       String
  workerName   String
  inputPayload Json
  outputPayload Json?
  startedAt    DateTime @default(now())
  finishedAt   DateTime?
  status       String
  errorMessage String?
  durationMs   Int?
  tokensUsed   Int?
  costUsd      Decimal? @db.Decimal(10, 6)

  task Task @relation(fields: [taskId], references: [id], onDelete: Cascade)

  @@index([taskId])
  @@index([startedAt])
}

model EventLog {
  id        String   @id @default(cuid())
  missionId String?
  taskId    String?
  eventType String
  payload   Json
  createdAt DateTime @default(now())

  mission Mission? @relation(fields: [missionId], references: [id], onDelete: SetNull)
  task    Task?    @relation(fields: [taskId], references: [id], onDelete: SetNull)

  @@index([missionId])
  @@index([taskId])
  @@index([eventType])
  @@index([createdAt])
}

model Approval {
  id          String         @id @default(cuid())
  missionId   String
  taskId      String?
  actionType  String
  requestedBy String
  status      ApprovalStatus @default(PENDING)
  approvedBy  String?
  notes       String?
  expiresAt   DateTime?
  createdAt   DateTime       @default(now())
  resolvedAt  DateTime?

  mission Mission  @relation(fields: [missionId], references: [id], onDelete: Cascade)
  task    Task?    @relation(fields: [taskId], references: [id], onDelete: SetNull)

  @@index([missionId])
  @@index([status])
}

model Artifact {
  id          String       @id @default(cuid())
  missionId   String
  taskId      String?
  artifactType ArtifactType
  pathOrUrl   String
  metadata    Json?
  createdAt   DateTime     @default(now())

  mission Mission @relation(fields: [missionId], references: [id], onDelete: Cascade)
  task    Task?   @relation(fields: [taskId], references: [id], onDelete: SetNull)

  @@index([missionId])
  @@index([artifactType])
}

model PromptVersion {
  id         String    @id @default(cuid())
  agentType  AgentType
  version    Int
  promptText String
  status     String    @default("draft")
  notes      String?
  createdAt  DateTime  @default(now())

  @@unique([agentType, version])
  @@index([agentType, status])
}
